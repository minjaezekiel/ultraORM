{
  "name": "ultraorm",
  "version": "2.1.0",
  "description": "The Ultimate Node.js ORM - Write once, run anywhere. PostgreSQL, MySQL, MongoDB support with Django-like ease. v2.1.0 ships critical bug fixes for Postgres schema generation, MoneyField corruption, belongsToMany eager loading, polymorphic relations, and identifier escaping.",
  "main": "bootstrap-orm.js",
  "module": "ultra-orm.js",
  "types": "ultra-orm.d.ts",
  "scripts": {
    "test": "node tests/runner.js",
    "test:unit": "node tests/unit.test.js",
    "test:integration": "node tests/integration.test.js",
    "test:performance": "node tests/performance.test.js",
    "migrate": "node -e \"require('./bootstrap-orm').migrate()\"",
    "migrate:make": "node -e \"require('./bootstrap-orm').makeMigration(process.argv[2])\"",
    "migrate:run": "node -e \"require('./bootstrap-orm').migrateRun()\"",
    "migrate:rollback": "node -e \"require('./bootstrap-orm').migrateRollback()\"",
    "migrate:reset": "node -e \"require('./bootstrap-orm').migrateReset()\"",
    "migrate:refresh": "node -e \"require('./bootstrap-orm').migrateRefresh()\"",
    "seed": "node -e \"require('./bootstrap-orm').seed()\"",
    "seed:make": "node -e \"require('./bootstrap-orm').makeSeeder(process.argv[2])\"",
    "seed:refresh": "node -e \"require('./bootstrap-orm').seedRefresh()\"",
    "db:connect": "node -e \"require('./bootstrap-orm').connect()\"",
    "db:disconnect": "node -e \"require('./bootstrap-orm').disconnect()\"",
    "lint": "eslint core.js bootstrap-orm.js ultra-orm.js",
    "docs": "jsdoc -d docs core.js"
  },
  "keywords": [
    "orm",
    "database",
    "postgres",
    "postgresql",
    "mysql",
    "mongodb",
    "mongo",
    "model",
    "query",
    "migration",
    "seeder",
    "relationships",
    "activerecord"
  ],
  "author": "Silivestir Assey, Ezekiel Minja",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minjaezekiel/ultraorm"
  },
  "bugs": {
    "url": "https://github.com/minjaezekiel/ultraorm/issues"
  },
  "homepage": "https://github.com/minjaezekiel/ultraorm#readme",
  "peerDependencies": {},
  "dependencies": {
    "dotenv": "^16.0.0",
    "pg": "^8.11.0",
    "mysql2": "^3.6.0",
    "mongodb": "^5.9.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.0",
    "jsdoc": "^4.0.0",
    "eslint": "^8.50.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
